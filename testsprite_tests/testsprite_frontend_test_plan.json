[
  {
    "id": "TC001",
    "title": "Create and publish a homework with Multiple Choice and True/False questions",
    "description": "Verifies an authenticated teacher can complete the create wizard, publish, and see the homework in the homework list.",
    "category": "Homework Creation",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the Login button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on \"Create\" or \"Create Homework\" in the dashboard navigation"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard/create\""
      },
      {
        "type": "action",
        "description": "Type \"Math Quiz 1\" into the homework title field"
      },
      {
        "type": "action",
        "description": "Click the \"Add Question\" button"
      },
      {
        "type": "action",
        "description": "Select \"Multiple Choice\" as the question type"
      },
      {
        "type": "action",
        "description": "Type \"What is 2 + 2?\" into the question text field"
      },
      {
        "type": "action",
        "description": "Type \"3\" into the first choice field"
      },
      {
        "type": "action",
        "description": "Type \"4\" into the second choice field"
      },
      {
        "type": "action",
        "description": "Click to mark the choice \"4\" as the correct answer"
      },
      {
        "type": "action",
        "description": "Click the \"Add Question\" button"
      },
      {
        "type": "action",
        "description": "Select \"True/False\" as the question type"
      },
      {
        "type": "action",
        "description": "Type \"The number 5 is greater than 3.\" into the question text field"
      },
      {
        "type": "action",
        "description": "Click the \"Publish\" button"
      },
      {
        "type": "action",
        "description": "Click on \"Homeworks\" in the dashboard navigation"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard/hw\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Math Quiz 1\" is visible"
      }
    ]
  },
